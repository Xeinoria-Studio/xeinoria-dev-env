# ─────────────────────────────────────────────────────────────────────────────
# _xeinoria_welcome.sk — chargé en premier (préfixe "_").
#
#   • Auto-op du tout premier joueur si aucun op n'existe (persistant, one-shot).
#   • Titre + message complet envoyés UNE SEULE FOIS par joueur (on first join).
#   • Liens cliquables via MiniMessage (rendu par SkBee).
#
# Auteur : Xeinoria Studio — Licence : CC BY-NC-SA 4.0
# ─────────────────────────────────────────────────────────────────────────────

options:
    container: xeinoria-dev
    sep: <dark_gray>----------------------------------------</dark_gray>

on first join:
    # ── Auto-op : seulement si aucun op n'existe encore ──────────────────────
    if {xeinoria.first_op_done} is not set:
        set {_has_op} to false
        loop all offline players:
            if loop-value is op:
                set {_has_op} to true
                exit loop
        if {_has_op} is false:
            op the player
            set {xeinoria.first_op_done} to true
            send "[xeinoria-dev] Auto-op : %player% (aucun opérateur préexistant)." to console
            send mini message from "<gold>[Xeinoria]</gold> <green>Tu es désormais opérateur (auto-op).</green>" to player

    # ── Titre de bienvenue ───────────────────────────────────────────────────
    send title "<aqua>Xeinoria Dev</aqua>" with subtitle "<gray>Environnement de test Skript</gray>" to player for 4 seconds

    # ── Message complet 5 s plus tard (laisse les plugins finir leur spam) ───
    wait 5 seconds
    if player is not online:
        stop

    send "" to player
    send mini message from "{@sep}" to player
    send mini message from "<gold>[Xeinoria]</gold> <white>Bienvenue, <yellow>%player%</yellow> !</white>" to player
    send mini message from "<gray>Cet environnement reproduit la stack Skript du réseau <aqua>Xeinoria</aqua>.</gray>" to player
    send mini message from "<gray>Tu peux y tester librement tes scripts avant production.</gray>" to player
    send "" to player

    send mini message from "<gold>● Documentation principale</gold>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://docs.skriptlang.org/'><blue><u>docs.skriptlang.org</u></blue></click> <dark_gray>(Skript officiel)</dark_gray>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://skripthub.net/docs/'><blue><u>skripthub.net/docs</u></blue></click> <dark_gray>(recherche globale)</dark_gray>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://docs.skunity.com/'><blue><u>docs.skunity.com</u></blue></click> <dark_gray>(alternative SkUnity)</dark_gray>" to player
    send "" to player

    send mini message from "<gold>● Addons Skript installés</gold> <dark_gray>(clic → doc)</dark_gray>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://docs.skriptlang.org/'><blue><u>Skript 2.15.2</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/SkriptLang/skript-reflect'><blue><u>skript-reflect 2.6.3</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/ShaneBeee/SkBee/wiki'><blue><u>SkBee 3.22.0</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/JakeGBLP/Lusk/wiki'><blue><u>Lusk 1.3.13</u></blue></click> <yellow>*</yellow>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/SkriptLang/skript-worldguard'><blue><u>skript-worldguard 1.0.1</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/skredis'><blue><u>SkRedis 2.3.1</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/skproxy'><blue><u>SkProxy 2.4</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/APickledWalrus/skript-placeholders'><blue><u>skript-placeholders 1.7.1</u></blue></click> <yellow>*</yellow>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/skript-translate'><blue><u>Skript-Translate 1.3</u></blue></click> <yellow>*</yellow>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/skript-db'><blue><u>skript-db 1.5.0</u></blue></click> <yellow>*</yellow>" to player
    send "" to player

    send mini message from "<gold>● Dépendances natives</gold>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://github.com/dmulloy2/ProtocolLib'><blue><u>ProtocolLib 5.4.0</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/packetevents'><blue><u>packetevents 2.12.1</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://enginehub.org/worldedit/'><blue><u>WorldEdit 7.4.3</u></blue></click> + <click:open_url:'https://enginehub.org/worldguard/'><blue><u>WorldGuard 7.0.16</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://luckperms.net/wiki'><blue><u>LuckPerms 5.5.53</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://commandapi.jorel.dev/'><blue><u>CommandAPI 11.2.0</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://wiki.decentholograms.eu/'><blue><u>DecentHolograms 2.9.10</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://modrinth.com/plugin/simple-voice-chat'><blue><u>Simple Voice Chat 2.6.17</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://placeholderapi.com/'><blue><u>PlaceholderAPI 2.12.2</u></blue></click>" to player
    send mini message from "  <gray>•</gray> <click:open_url:'https://hangar.papermc.io/TNE/VaultUnlocked'><blue><u>VaultUnlocked 2.17.0</u></blue></click> + <click:open_url:'https://hangar.papermc.io/TNE/TheNewEconomy'><blue><u>TheNewEconomy 0.1.4.0</u></blue></click>" to player
    send "" to player
    send mini message from "  <yellow>*</yellow> <gray><italic>marqué pour MC ≤ 1.21.4 mais charge sans souci visible sur Paper 26.1.2.</italic></gray>" to player
    send "" to player

    send mini message from "<gold>● Tutoriel Docker — console serveur</gold>" to player
    send mini message from "  <gray>1. Depuis ton terminal hôte :</gray> <click:copy_to_clipboard:'docker attach {@container}'><hover:show_text:'<gray>Cliquer pour copier'><white><u>docker attach {@container}</u></white></hover></click>" to player
    send mini message from "  <gray>2. Tu obtiens la console Minecraft → tape <white>op [Pseudo]</white>, <white>stop</white>, etc.</gray>" to player
    send mini message from "  <gray>3. Pour <yellow>quitter sans arrêter le serveur</yellow> :</gray> <white>Ctrl+P</white> <gray>puis</gray> <white>Ctrl+Q</white>" to player
    send mini message from "     <dark_gray>(Ctrl+C dans un attach <red>tue</red> le serveur — à éviter.)</dark_gray>" to player
    send "" to player

    send mini message from "<gold>● Crédits & licence</gold>" to player
    send mini message from "  <gray>Image <aqua>xeinoria-dev-env</aqua> par <white>Xeinoria Studio</white>.</gray>" to player
    send mini message from "  <gray>Code sous <click:open_url:'https://creativecommons.org/licenses/by-nc-sa/4.0/'><blue><u>CC BY-NC-SA 4.0</u></blue></click> — attribution requise, non commercial, partage à l'identique.</gray>" to player
    send mini message from "  <gray>Merci aux auteurs des addons listés ci-dessus.</gray>" to player
    send mini message from "{@sep}" to player
